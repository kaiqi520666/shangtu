# 模型配置
QWEN_TEXT_MODEL=qwen3.6-flash
IMAGE_GENERATE_MODEL=gpt-image-2
VIDEO_GENERATE_MODEL=happyhorse-1.0

# ToAPIS 生图/视频异步任务
TOAPIS_KEY=
TOAPIS_URL=https://toapis.com

# HeyGen 数字人/声音
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_API_KEY=

# Worker 可选配置
# ARQ_MAX_JOBS=5
# ARQ_JOB_TIMEOUT=3000

# ZPAY 微信支付充值
ZPAY_PID=
ZPAY_KEY=
ZPAY_GATEWAY=https://zpayz.cn
ZPAY_NOTIFY_URL=http://127.0.0.1:8000/billing/zpay/notify
