OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# DashScope 图像分析
DASHSCOPE_URL=
DASHSCOPE_API_KEY=

# DashScope 非实时语音合成
DASHSCOPE_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
