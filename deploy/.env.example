# 复制为 .env 并填写真实值，不要提交到 git

# 前端容器映射到主机的端口（如与服务器上其它项目冲突可改）
FRONTEND_PORT=8090

# PostgreSQL（容器内数据库，数据落在 ./data/postgres）
POSTGRES_USER=shangtu
POSTGRES_PASSWORD=
POSTGRES_DB=shangtu

# JWT 签名密钥（务必修改为随机字符串）
SECRET_KEY=

# 阿里云 OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# DashScope 图像分析
DASHSCOPE_URL=
DASHSCOPE_API_KEY=

# 模型配置
QWEN_TEXT_MODEL=qwen3.6-flash
IMAGE_GENERATE_MODEL=gpt-image-2
VIDEO_GENERATE_MODEL=seedance-2

# ToAPIS 生图/视频异步任务
TOAPIS_KEY=
TOAPIS_URL=https://toapis.com

# ZPAY 微信支付充值
ZPAY_PID=
ZPAY_KEY=
ZPAY_GATEWAY=https://zpayz.cn
ZPAY_NOTIFY_URL=https://your-domain.com/api/billing/zpay/notify
ZPAY_RETURN_URL=https://your-domain.com/api/billing/zpay/return

# 扣费价格和充值套餐在管理后台「系统设置」中配置

# Worker 可选配置
# ARQ_MAX_JOBS=5
# ARQ_JOB_TIMEOUT=3000
