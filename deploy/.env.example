# 复制为 .env 并填写真实值，不要提交到 git

# 前端容器映射到主机的端口（如与服务器上其它项目冲突可改）
FRONTEND_PORT=8088

# PostgreSQL（容器内数据库，数据落在 ./data/postgres）
POSTGRES_USER=shangtu
POSTGRES_PASSWORD=
POSTGRES_DB=shangtu

# JWT 签名密钥（必填，建议使用 openssl rand -hex 32 生成）
SECRET_KEY=

# 腾讯云 SES 注册验证码
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_SES_REGION=ap-hongkong
TENCENT_SES_FROM_EMAIL=no-reply@mail.nodepass.net
TENCENT_SES_TEMPLATE_ID=204003

# Cloudflare Turnstile 人机验证
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 阿里云 OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# DashScope 图像分析
DASHSCOPE_URL=
DASHSCOPE_API_KEY=

# DashScope 非实时语音合成
DASHSCOPE_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
DASHSCOPE_TTS_MODEL=cosyvoice-v3-flash

# 模型配置
QWEN_TEXT_MODEL=qwen3.6-flash
IMAGE_GENERATE_MODEL=gpt-image-2
VIDEO_PROVIDER=topenrouter
VIDEO_GENERATE_MODEL=wan2.5-i2v-preview

# ToAPIS 生图/视频异步任务
TOAPIS_KEY=
TOAPIS_URL=https://toapis.com

# TopenRouter 视频生成
TOPENROUTER_URL=https://tp-api.chinadatapay.com:8000
TOPENROUTER_KEY=

# HeyGen 数字人/视频翻译
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_API_KEY=

# ZPAY 微信支付充值
ZPAY_PID=
ZPAY_KEY=
ZPAY_GATEWAY=https://zpayz.cn
ZPAY_NOTIFY_URL=https://your-domain.com/api/billing/zpay/notify
ZPAY_RETURN_URL=https://your-domain.com/api/billing/zpay/return

# 扣费价格和充值套餐在管理后台「系统设置」中配置

# Worker 可选配置
# ARQ_MAX_JOBS=5
# ARQ_JOB_TIMEOUT=3000
